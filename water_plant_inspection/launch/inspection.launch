<launch>
  <!--
    水厂巡检任务启动文件
    启动导航栈 + RViz + 巡检节点

    使用方式（在 simulation.launch 启动并完成 2→5 模式切换后）：
      Terminal 2: roslaunch water_plant_inspection inspection.launch
  -->

  <!-- GT pose 接口 -->
  <include file="$(find unitree_move_base)/launch/gtPoseAndScan.launch"/>

  <!-- TARE + FAR-Planner 导航栈 -->
  <include file="$(find unitree_move_base)/launch/tare_far_navigation.launch"/>

  <!-- RViz -->
  <node pkg="rviz" type="rviz" name="rviz"
        args="-d $(find unitree_move_base)/config/tare_navigation.rviz"
        output="log"/>

  <!-- 巡检控制节点 -->
  <node pkg="water_plant_inspection" type="inspection_node.py"
        name="inspection_node" output="screen" required="false">
    <param name="config_file"
           value="$(find water_plant_inspection)/config/inspection_points.yaml"/>
  </node>

</launch>
